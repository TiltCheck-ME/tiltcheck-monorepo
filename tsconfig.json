{
  "compilerOptions": {
    "paths": {
      "@tiltcheck/auth": ["./packages/auth/src/index.ts"],
      "@tiltcheck/auth/*": ["./packages/auth/src/*"],
      "@tiltcheck/auth-flow": ["./packages/auth-flow/src/index.ts"],
      "@tiltcheck/types": ["./packages/types/src/index.ts"],
      "@tiltcheck/types/*": ["./packages/types/src/*"],
      "@tiltcheck/config": ["./packages/config/src/index.ts"],
      "@tiltcheck/config/*": ["./packages/config/src/*"],
      "@tiltcheck/db": ["./packages/db/src/index.ts"],
      "@tiltcheck/db/*": ["./packages/db/src/*"],
      "@tiltcheck/database": ["./packages/database/src/index.ts"],
      "@tiltcheck/database/*": ["./packages/database/src/*"],
      "@tiltcheck/tiltcheck-core": ["./modules/tiltcheck-core/src/index.ts"],
      "@tiltcheck/tiltcheck-core/*": ["./modules/tiltcheck-core/src/*"],
      "@tiltcheck/event-router": ["./packages/event-router/src/index.ts"],
      "@tiltcheck/event-router/*": ["./packages/event-router/src/*"],
      "@tiltcheck/error-factory": ["./packages/error-factory/src/index.ts"],
      "@tiltcheck/error-factory/*": ["./packages/error-factory/src/*"],
      "@tiltcheck/utils": ["./packages/utils/src/index.ts"],
      "@tiltcheck/utils/*": ["./packages/utils/src/*"],
      "@tiltcheck/event-types": ["./packages/event-types/src/index.ts"],
      "@tiltcheck/event-types/*": ["./packages/event-types/src/*"],
      "@tiltcheck/justthetip": ["./modules/justthetip/src/index.ts"],
      "@tiltcheck/justthetip/*": ["./modules/justthetip/src/*"],
      "@tiltcheck/lockvault": ["./modules/lockvault/src/index.ts"],
      "@tiltcheck/lockvault/*": ["./modules/lockvault/src/*"],
      "@tiltcheck/suslink": ["./modules/suslink/src/index.ts"],
      "@tiltcheck/suslink/*": ["./modules/suslink/src/*"],
      "@tiltcheck/natural-language-parser": ["./packages/natural-language-parser/src/index.ts"],
      "@tiltcheck/natural-language-parser/*": ["./packages/natural-language-parser/src/*"],
      "@tiltcheck/trust-engines": ["./packages/trust-engines/src/index.ts"],
      "@tiltcheck/trust-engines/*": ["./packages/trust-engines/src/*"],
      "@tiltcheck/trust-score-types": ["./packages/trust-score-types/src/index.ts"],
      "@tiltcheck/trust-score-types/*": ["./packages/trust-score-types/src/*"],
      "@tiltcheck/validator": ["./packages/validator/src/index.ts"],
      "@tiltcheck/validator/*": ["./packages/validator/src/*"]
    },
    "rootDir": ".",
    "outDir": "./dist",
    "skipLibCheck": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ESNext",
    "composite": true,
    "incremental": true,
    "declaration": true,
    "strict": true,
    "types": [
      "node"
    ]
  },
  "exclude": [
    "node_modules",
    "dist",
    "tmp/**",
    "tests/**",
    "**/tests/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "apps/chrome-extension/**"
  ]
}
