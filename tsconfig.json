{
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "./dist",
    "skipLibCheck": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "target": "ESNext",
    "composite": true,
    "incremental": true,
    "declaration": true,
    "strict": true
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}
