{
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "@tiltcheck/*": [
        "packages/*/src/index.ts",
        "packages/*",
        "packages/*/src",
        "modules/*/src/index.ts",
        "modules/*",
        "modules/*/src"
      ]
    },
    "outDir": "./dist",
    "declaration": true,
    "skipLibCheck": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "target": "ESNext",
    "incremental": false,
    "strict": true
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}
