{
    "name": "tiltcheck-channel-watcher",
    "version": "2.0.0",
    "description": "On-demand Discord channel scraper — batch collects messages since last checkpoint, runs GPT-4o pain point analysis, and exits",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "start": "node index.js",
        "full": "node index.js --full",
        "live": "node index.js --live",
        "10m": "node index.js --live --duration=10",
        "history": "node index.js --full",
        "analyze": "node analyze-log.js",
        "analyze:lore": "node analyze-log.js --lore"
    },
    "dependencies": {
        "playwright": "^1.41.0",
        "chalk": "^5.3.0",
        "dotenv": "^16.4.5"
    }
}