# Channel Watcher Configuration
# Copy this to .env and fill in your values

# Discord channel URL to watch
# Right-click the channel in Discord → Copy Link
WATCH_CHANNEL_URL=

# ─── AI Provider ────────────────────────────────────────────────────────────
# Which provider to use for analysis:
#   ollama   — local, completely free, no key needed (needs Ollama running)
#   groq     — free cloud, fast, no credit card (get key at console.groq.com)
#   gemini   — free tier 1M tokens/day (get key at aistudio.google.com)
#   openai   — pay per use (get key at platform.openai.com)
#   all      — runs ALL configured providers in parallel, one report per model
PROVIDER=ollama

# Ollama (local) — no key needed, but Ollama must be running
# Install: https://ollama.ai — then: ollama pull llama3.2
OLLAMA_URL=http://localhost:11434/v1

# Optional: GCP burst-run settings for run-cloud-watcher.ps1 / npm run cloud
# The script will start VM, wait for Ollama, run watcher, then stop VM.
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_VM_NAME=ollama-vm
# GCP_VM_ZONE=us-central1-a
# Optional override if you prefer fixed IP instead of auto-resolve:
# GCP_VM_IP=34.9.37.47

# ─── Daily Comic Generation ───────────────────────────────────────────────────
# Uses Ollama-compatible /chat/completions endpoint by default.
# Set COMIC_USE_AI=false to force heuristic fallback mode.
COMIC_USE_AI=true
COMIC_MODEL=llama3.2
COMIC_TIMEZONE=UTC
COMIC_CREATOR=jmenichole
COMIC_VISUAL_ARTIST=samoxic

# Groq (free cloud) — sign up at console.groq.com, no card required
GROQ_API_KEY=

# Google Gemini (free tier) — get key at aistudio.google.com
GEMINI_API_KEY=

# OpenAI (paid) — get key at platform.openai.com
OPENAI_API_KEY=

# Override the model for any provider (optional)
# AI_MODEL=llama3.2

# ─── Scrape limits ────────────────────────────────────────────────────────────
# Max messages to collect per run before stopping the scroll
MAX_MESSAGES=400

# How many hours back to look (the more recent of this or your last checkpoint wins)
LOOKBACK_HOURS=48

# Max messages to send to AI (smart-samples if over this)
GPT_MAX_MESSAGES=300

# Show the browser window while scraping (false = headless/invisible)
SHOW_BROWSER=true
