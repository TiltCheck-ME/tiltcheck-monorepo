# Channel Watcher Configuration
# Copy this to .env and fill in your values.
# On Railway, set these as environment variables in the service settings.

# Discord channel URL to watch
# Right-click the channel in Discord -> Copy Link
WATCH_CHANNEL_URL=

# ─── Discord Auth ─────────────────────────────────────────────────────────────
# PREFERRED: Just your raw Discord user token (~70 chars). Much smaller than
# the full session JSON. Set this in Railway instead of DISCORD_SESSION_JSON.
#
# How to get it:
#   1. Open Discord in a browser (discord.com/app)
#   2. Open DevTools (F12) -> Network tab
#   3. Click any channel — find a request to discord.com/api/
#   4. Look at the "Authorization" request header — that's your token
#
# Or: after running `npm run session:create`, run `npm run token:get`
DISCORD_TOKEN=

# LEGACY: Full session JSON (base64 or raw). Use DISCORD_TOKEN above instead —
# this value can exceed Railway's 32KB env var limit.
# DISCORD_SESSION_JSON=

# ─── Persistent Data Directory ────────────────────────────────────────────────
# Railway: mount a Volume at /data and set this.
# Local: leave blank (defaults to the tool directory).
# DATA_DIR=/data

# ─── AI Provider ─────────────────────────────────────────────────────────────
# groq   — free, fast, no credit card (recommended for Railway)
# gemini — free tier 1M tokens/day
# openai — pay per use
PROVIDER=groq

# Groq (free) — sign up at console.groq.com
GROQ_API_KEY=

# Google Gemini (free tier) — aistudio.google.com
GEMINI_API_KEY=

# OpenAI — platform.openai.com
OPENAI_API_KEY=

# Override model for any provider (optional)
# AI_MODEL=llama-3.3-70b-versatile

# ─── Reporting ────────────────────────────────────────────────────────────────
# Discord webhook to post analysis reports to (optional)
DEV_UPDATES_WEBHOOK_URL=

# Trust engine ingest endpoint (optional)
TRUST_ENGINE_INGEST_URL=
COMMUNITY_INTEL_INGEST_KEY=

# ─── Scrape limits ────────────────────────────────────────────────────────────
MAX_MESSAGES=400
LOOKBACK_HOURS=48
GPT_MAX_MESSAGES=300

# ─── Daily Comic ─────────────────────────────────────────────────────────────
COMIC_USE_AI=true
COMIC_MODEL=llama3.2:3b
COMIC_TIMEZONE=UTC
COMIC_CREATOR=jmenichole
COMIC_VISUAL_ARTIST=samoxic
COMIC_MAX_MESSAGES=180
COMIC_API_URL=
COMIC_API_INGEST_KEY=
COMIC_COMMUNITY_ID=tiltcheck-discord

