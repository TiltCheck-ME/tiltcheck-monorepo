# Channel Watcher Configuration
# Copy this to .env and fill in your values

# Discord channel URL to watch
# Right-click the channel in Discord → Copy Link
# e.g. https://discord.com/channels/1234567890/9876543210
WATCH_CHANNEL_URL=

# Your OpenAI API key for GPT-4o-mini analysis
# If left blank, messages are still logged to file but no AI analysis runs
OPENAI_API_KEY=

# How often to run the AI analysis and generate a report (minutes)
# Default: every 2 hours
ANALYSIS_INTERVAL_MINUTES=120

# How many messages to buffer before forcing an early analysis flush
MAX_BUFFER_SIZE=300

# Path to save the running message log (raw JSONL)
LOG_FILE_PATH=./messages.jsonl

# Show the browser window while it runs (true = visible, false = headless)
# Keep true so you can see it's working and stay logged in
SHOW_BROWSER=true
