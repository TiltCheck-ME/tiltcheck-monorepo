{
  "manifest_version": 3,
  "name": "TiltCheck",
  "version": "1.2.0",
  "description": "Real-time gambling behavior tracker, tilt detection, and bankroll management tools.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.stake.com/*",
    "https://*.stake.us/*",
    "https://*.roobet.com/*",
    "https://*.bc.game/*",
    "https://*.rollbit.com/*",
    "https://*.shuffle.com/*",
    "https://*.gamdom.com/*",
    "https://*.csgoempire.com/*",
    "https://*.tiltcheck.me/*",
    "https://api.tiltcheck.me/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle TiltCheck Sidebar"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.stake.com/*",
        "https://*.stake.us/*",
        "https://*.roobet.com/*",
        "https://*.bc.game/*",
        "https://*.rollbit.com/*",
        "https://*.shuffle.com/*",
        "https://*.gamdom.com/*",
        "https://*.csgoempire.com/*",
        "https://*.tiltcheck.me/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.stake.com/*",
        "https://*.stake.us/*",
        "https://*.roobet.com/*",
        "https://*.bc.game/*",
        "https://*.rollbit.com/*",
        "https://*.shuffle.com/*",
        "https://*.gamdom.com/*",
        "https://*.csgoempire.com/*",
        "https://*.tiltcheck.me/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "page-bridge.js"
      ],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
