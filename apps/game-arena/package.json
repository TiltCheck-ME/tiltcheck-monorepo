{
  "name": "@tiltcheck/game-arena",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Web-based multiplayer game arena for DA&D and Poker with Discord auth",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tiltcheck/database": "workspace:*",
    "@tiltcheck/dad": "workspace:*",
    "@tiltcheck/db": "workspace:*",
    "@tiltcheck/discord-monetization": "workspace:*",
    "@tiltcheck/event-router": "workspace:*",
    "@tiltcheck/justthetip": "workspace:*",
    "@tiltcheck/supabase-auth": "workspace:*",
    "@tiltcheck/types": "workspace:*",
    "connect-redis": "^9.0.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/uuid": "^11.0.0",
    "tsx": "^4.21.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
