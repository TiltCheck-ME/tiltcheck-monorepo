{
  "name": "@tiltcheck/trust-rollup",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests tests"
  },
  "dependencies": {
    "@tiltcheck/event-router": "workspace:*",
    "@tiltcheck/shared": "workspace:*",
    "@tiltcheck/tiltcheck-core": "workspace:*",
    "@tiltcheck/types": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
