{
  "name": "@tiltcheck/discord-bot",
  "version": "0.1.0",
  "description": "TiltCheck safety, accountability, and casino trust audit bot",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/bootstrap.ts",
    "start": "node dist/bootstrap.js",
    "clean": "rm -rf dist",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "clear:global": "tsx src/cleanup-commands.ts --all",
    "clear:guild": "tsx src/cleanup-commands.ts --guild --all",
    "clear:names": "tsx src/cleanup-commands.ts"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@supabase/supabase-js": "^2.45.0",
    "@solana/pay": "^0.2.6",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@discord/embedded-app-sdk": "^2.4.1",
    "@tiltcheck/config": "workspace:*",
    "@tiltcheck/dad": "workspace:*",
    "@tiltcheck/database": "workspace:*",
    "@tiltcheck/discord-activities": "workspace:*",
    "@tiltcheck/discord-utils": "workspace:*",
    "@tiltcheck/esm-utils": "workspace:*",
    "@tiltcheck/event-router": "workspace:*",
    "@tiltcheck/justthetip": "workspace:*",
    "@tiltcheck/natural-language-parser": "workspace:*",
    "@tiltcheck/shared": "workspace:*",
    "@tiltcheck/suslink": "workspace:*",
    "@tiltcheck/tiltcheck-core": "workspace:*",
    "@tiltcheck/trust-engines": "workspace:*",
    "@tiltcheck/types": "workspace:*",
    "@tiltcheck/utils": "workspace:*",
    "bignumber.js": "^10.0.2",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "openai": "^6.33.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^2.6.13",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
