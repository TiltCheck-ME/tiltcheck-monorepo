# IMPORTANT: ROTATE ALL COMPROMISED KEYS IMMEDIATELY
# Values set in Railway / your deployment platform override these.
# Copy this file to .env and fill in real values for local dev.

# --- CORE DEPLOYMENT ---
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
PUBLIC_BASE_URL=http://localhost:3000
SITE_URL=https://tiltcheck.me
STAGING_URL=https://staging.tiltcheck.me
API_URL=http://localhost:3000/api
API_BASE_URL=http://localhost:3000/api
BACKEND_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3000/dashboard
# NEXT_PUBLIC_API_URL: primary public-facing API base (replaces NEXT_PUBLIC_BACKEND_URL)
NEXT_PUBLIC_API_URL=http://localhost:3000/api
# NEXT_PUBLIC_DASHBOARD_URL: Base URL for the user-dashboard app, consumed by apps/web via
# getDashboardBaseUrl() in src/lib/dashboard-handoff.ts. Falls back to
# http://localhost:6001 in development and https://dashboard.tiltcheck.me in production
# when this variable is unset.
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:6001
NEXT_RUNTIME=nodejs
TILTCHECK_API_URL=http://localhost:3000/api
TILT_API_BASE_URL=http://localhost:3000/api
WS_URL=ws://localhost:3000/ws
ALLOWED_ORIGINS=http://localhost:3001,https://tiltcheck.me
HEALTH_CHECK_HOST=0.0.0.0
METRICS_ENDPOINT=
MONOREPO_ROOT=/app
TILTCHECK_ROOT=/app
SKIP_ENV_VALIDATION=false

