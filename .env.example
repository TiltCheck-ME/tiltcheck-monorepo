# --- AI PROVIDERS (smart routing: vertex → groq → ollama → mock) ---
# Vertex AI (primary for accuracy-critical tasks: tilt-detection, moderation, etc.)
# Uses your GCP billing credits. Set up a service account and paste the full JSON:
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}
GOOGLE_CLOUD_PROJECT=tiltcheck
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash

# Groq (primary for speed-critical tasks: nl-commands, support, card-generation)
# Free tier: https://console.groq.com — generous rate limits
GROQ_API_KEY=REPLACE_ME
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Ollama (local dev / self-hosted fallback — only active in development)
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:1b

# OpenAI (optional fourth provider)
OPENAI_API_KEY=ROTATE_THIS_IMMEDIATELY
OPENAI_MODEL=gpt-4o-mini

# Force a single provider for all tasks (overrides smart routing)
# Options: vertex | groq | ollama | openai | mock
# Leave blank to use smart routing (recommended)
AI_PROVIDER=

