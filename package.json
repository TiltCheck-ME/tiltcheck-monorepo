{
  "name": "tiltcheck-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TiltCheck Ecosystem - Behavioral protection for a better experience",
  "author": "jmenichole",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.29.1",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --recursive dev",
    "dev:core": "pnpm --filter @tiltcheck/api --filter web --filter @tiltcheck/discord-bot --parallel dev",
    "discord:setup": "pnpm --filter @tiltcheck/discord-bot run deploy:commands",
    "build": "pnpm -r build",
    "build:legacy": "pnpm -r --workspace-concurrency=1 build",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:all": "pnpm --recursive test",
    "coverage": "vitest run --coverage",
    "coverage:ci": "CI=true vitest run --coverage",
    "lint": "eslint \"apps/**/*.ts\" \"modules/**/*.ts\" \"services/**/*.ts\" \"packages/**/*.ts\"",
    "lint:fix": "pnpm lint --fix",
    "clean": "pnpm --recursive clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "bundle:components": "bash scripts/bundle-components.sh",
    "contrast": "node scripts/contrast-check.cjs",
    "contrast:dom": "node scripts/contrast-check-dom.cjs",
    "a11y:serve": "node scripts/serve-components.cjs",
    "a11y:audit": "bash scripts/a11y-audit.sh",
    "a11y:serve:landing": "node scripts/serve-landing.cjs",
    "a11y:audit:landing": "bash scripts/landing-a11y-audit.sh",
    "test:components": "node scripts/validate-components.cjs",
    "audit:all": "pnpm test:components && pnpm bundle:components && pnpm contrast && pnpm contrast:dom && pnpm a11y:audit && pnpm a11y:audit:landing",
    "audit:images": "node scripts/audit-images.js",
    "audit:a11y:landing": "node scripts/a11y-regression-landing.js",
    "ci:landing": "vitest --run landing-image-integration.test.ts && pnpm audit:images && pnpm audit:a11y:landing",
    "optimize:images": "node scripts/optimize-images.js",
    "lighthouse:landing": "node scripts/run-lighthouse.js",
    "build:search-index": "node scripts/build-search-index.js",
    "lighthouse:ci": "node scripts/lighthouse-ci.js",
    "duo:hygiene:check": "node scripts/devx-duo-agent.mjs --check --config scripts/duo-agent.config.json",
    "duo:hygiene:apply": "node scripts/devx-duo-agent.mjs --apply --config scripts/duo-agent.config.json",
    "duo:docs:check": "node scripts/devx-duo-docs-agent.mjs --check --config scripts/duo-docs-agent.config.json",
    "duo:docs:apply": "node scripts/devx-duo-docs-agent.mjs --apply --config scripts/duo-docs-agent.config.json",
    "knip": "knip",
    "knip:report": "knip --reporter github-actions --no-progress --no-exit-code",
    "knip:ci": "knip --no-progress --production --include unresolved --include binaries",
    "deadcode": "pnpm knip",
    "ci:deploy:scripts": "node scripts/check-deploy-scripts.mjs",
    "ops:linear:dry": "node scripts/linear-sync.mjs --dry-run",
    "ops:linear:sync": "node scripts/linear-sync.mjs",
    "ops:daily": "powershell -ExecutionPolicy Bypass -File ./scripts/daily-ops.ps1",
    "seed:casino-trust": "node scripts/seed-casino-trust-from-scrape.js --include-existing --runtime-output ./data/casino-trust.json",
    "ops:task-ai": "node scripts/daily-task-ai.mjs",
    "trust:build": "pnpm --filter @tiltcheck/trust-engines build",
    "trust:start": "pnpm trust:build && node scripts/start-trust-engine-check.mjs"
  },
  "devDependencies": {
    "@google-cloud/secret-manager": "^6.1.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.1",
    "knip": "^6.1.0",
    "lighthouse": "^13.0.3",
    "lunr": "^2.3.9",
    "pa11y": "^9.1.1",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "bigint-buffer": "npm:@gsknnft/bigint-buffer@1.3.2",
      "esbuild@<=0.24.2": ">=0.25.0",
      "semver@>=7.0.0 <7.5.2": ">=7.5.2",
      "jws@<3.2.3": ">=3.2.3",
      "systeminformation@<5.27.14": ">=5.27.14",
      "basic-ftp": ">=5.1.1",
      "minimatch": ">=9.0.5",
      "hono": ">=4.12.0",
      "undici": ">=6.21.4",
      "lodash": ">=4.17.21",
      "socket.io-parser": ">=4.2.6",
      "fast-xml-parser": ">=5.5.7",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "yaml": ">=2.8.3",
      "smol-toml": ">=1.6.1",
      "brace-expansion": ">=5.0.5",
      "@eslint/plugin-kit": ">=0.3.5"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "keccak",
      "sharp",
      "unrs-resolver",
      "utf-8-validate",
      "workerd"
    ]
  }
}
