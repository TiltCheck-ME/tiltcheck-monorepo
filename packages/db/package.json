{
  "name": "@tiltcheck/db",
  "version": "0.1.1",
  "description": "Neon PostgreSQL database client for TiltCheck ecosystem",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest --run --passWithNoTests"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@tiltcheck/config": "workspace:*",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./queries": {
      "types": "./dist/queries.d.ts",
      "import": "./dist/queries.js"
    }
  }
}
