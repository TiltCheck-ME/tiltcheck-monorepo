{
  "_comment": "© 2024–2026 TiltCheck Ecosystem. All Rights Reserved. Last Updated: 2026-04-13",
  "name": "@tiltcheck/agent",
  "version": "1.0.0",
  "description": "AI Agent built with Google ADK (TypeScript)",
  "type": "module",
  "main": "dist/packages/agent/app/agent.js",
  "types": "dist/packages/agent/app/agent.d.ts",
  "exports": {
    ".": {
      "types": "./dist/packages/agent/app/agent.d.ts",
      "import": "./dist/packages/agent/app/agent.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc && npx @google/adk-devtools web -h localhost dist/packages/agent/app/agent.js",
    "run": "tsc && npx @google/adk-devtools run dist/packages/agent/app/agent.js",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@google/adk": "^0.6.0",
    "@google/adk-devtools": "^0.6.0",
    "@tiltcheck/database": "workspace:*",
    "zod": "^4.3.6"
  }
}
