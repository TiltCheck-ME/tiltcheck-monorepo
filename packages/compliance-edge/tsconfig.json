{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "composite": true,
    "incremental": true,
    "outDir": "./dist",
    "rootDir": "src",
    "declaration": true,
    "module": "NodeNext",
    "target": "ESNext",
    "lib": ["ESNext"],
    "moduleResolution": "NodeNext",
    "types": ["@cloudflare/workers-types"]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "wrangler.toml"
  ],
  "references": []
}
