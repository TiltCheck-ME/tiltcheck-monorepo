PORT=8080
COMIC_DEFAULT_COMMUNITY=tiltcheck-discord
COMIC_MAX_MESSAGES=180
COMIC_ARCHIVE_LIMIT=180
COMIC_GENERATION_RETRIES=2

# Optional shared key for POST /v1/comic/generate
COMIC_INGEST_KEY=

# Gemini (direct API — no Vertex AI / GCP required)
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# Cloudflare R2 Storage (replaces GCS)
COMIC_R2_BUCKET=REPLACE_ME
COMIC_R2_ENDPOINT=REPLACE_ME
COMIC_STORAGE_PREFIX=comics
R2_ACCOUNT_ID=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME

# Attribution defaults
COMIC_CREATOR=jmenichole
COMIC_VISUAL_ARTIST=samoxic
