{
  "name": "@tiltcheck/shared",
  "version": "0.1.0",
  "description": "Shared SDK for TiltCheck API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tiltcheck/types": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js"
    },
    "./legal": {
      "types": "./dist/legal.d.ts",
      "import": "./dist/legal.js"
    },
    "./fairness": {
      "types": "./dist/fairness.d.ts",
      "import": "./dist/fairness.js"
    },
    "./community-casinos": {
      "types": "./dist/community-casinos.d.ts",
      "import": "./dist/community-casinos.js"
    }
  }
}
